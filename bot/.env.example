# Скопируй в .env и заполни своими данными
# .env добавить в .gitignore — никогда не коммить реальные ключи!

# Получить на: https://open.ctrader.com → My Apps → New Application
CTRADER_CLIENT_ID=your_client_id_here
CTRADER_CLIENT_SECRET=your_client_secret_here

# OAuth токен для торгового аккаунта
# Получить через OAuth flow: https://connect.spotware.com/apps/auth
CTRADER_ACCESS_TOKEN=your_access_token_here

# ID торгового аккаунта (число, видно в cTrader платформе)
CTRADER_ACCOUNT_ID=12345678

# demo.ctraderapi.com — для тестирования
# live.ctraderapi.com  — для реальных денег (НЕ ТОРОПИСЬ!)
CTRADER_HOST=demo.ctraderapi.com
CTRADER_PORT=5035

# Уровень логирования: trace / debug / info / warn / error
RUST_LOG=ctrader_bot=debug
